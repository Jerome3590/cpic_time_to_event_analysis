# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare text files you want to always be normalized and converted
# to native line endings on checkout
*.sh text eol=lf
*.py text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.csv text eol=lf
*.tsv text eol=lf
*.R text eol=lf
*.r text eol=lf
*.ipynb text eol=lf filter=nbstripout
*.qmd text eol=lf
*.sql text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf

# Denote all files that are truly binary and should not be modified
*.parquet binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.bz2 binary
*.xz binary
*.7z binary
*.pkl binary
*.pickle binary
*.joblib binary
*.cbm binary
*.h5 binary
*.hdf5 binary
*.feather binary
*.arrow binary
