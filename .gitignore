# ── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
.cursor/
.cursorignore
.cursorrules
.windsurf/
.Rproj.user
.Rproj*
*.Rhistory
.luarc.json
.trunk/

# ── Python ────────────────────────────────────────────────────────────────────
.venv/
.venv*/
.venv-offline/
__pycache__/
*.pyc
.pytest_cache/
.ipynb_checkpoints/

# ── Data (generated — sync from S3) ──────────────────────────────────────────
data/*
from_s3/*
*/outputs/*
*/model_outputs/*
s3_outputs/

# ── Model data parquet (generated) ───────────────────────────────────────────
4_model_data/*
4_model_data/*/**
!4_model_data/*.py
!4_model_data/README*.md

# ── Final model inputs (generated) ───────────────────────────────────────────
6_final_model/inputs/

# ── FFA results (generated) ──────────────────────────────────────────────────
8_ffa_analysis/results/

# ── CatBoost training artifacts ──────────────────────────────────────────────
catboost_info/
*.cbm

# ── Credentials & secrets ────────────────────────────────────────────────────
secrets/
secrets.txt
**/secrets.txt
**/credentials.txt
**/session_cookies.json
**/.env
.env

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Status artifacts ─────────────────────────────────────────────────────────
# Keep figures, tables, PDFs, and JSON summaries trackable when they are used as
# QA or manuscript evidence. Ignore only the local upload tracker.
status/s3_upload_tracker.json

# ── Local cache/temporary ─────────────────────────────────────────────────────
tmp/

# ── Evidence artifacts ────────────────────────────────────────────────────────
# Do not globally ignore visual, tabular, or document evidence files such as
# PNG/HTML figures, CSV/JSON tables, PDF/DOCX/XLSX documents, or markdown notes.

# ── Node.js ───────────────────────────────────────────────────────────────────
**/node_modules/
**/package-lock.json
npm-debug.log*
yarn-error.log*

# ── Local AWS generated artifacts ─────────────────────────────────────────────
aws/**/__pycache__/
aws/**/*.pyc
aws/**/.env
aws/**/athena-results/
aws/**/query-results/
